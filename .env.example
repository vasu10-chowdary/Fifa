# PulseOS Environment Configuration
# Copy this file to .env and fill in values

# Application
APP_ENV=production
APP_VERSION=3.0.0
APP_BASE_URL=https://pulseos.fifa.com

# Session
SESSION_SECRET=your-secret-key-here
SESSION_TIMEOUT_MINUTES=60

# AI Integration
AI_SERVICE_URL=https://api.openai.com/v1
AI_API_KEY=your-api-key-here

# Security
CSRF_SECRET=your-csrf-secret-here
ALLOWED_ORIGINS=https://pulseos.fifa.com,https://dashboard.fifa.com

# Monitoring
MONITORING_ENDPOINT=https://monitoring.fifa.com/logs
AUDIT_LOG_MAX_ENTRIES=500
